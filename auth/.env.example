# Must be identical to the JWT_SECRET in Quarc Music's and Quarc Notes' .env files,
# otherwise tokens issued here won't verify there (and vice versa).
JWT_SECRET=change-me-to-a-long-random-string

ADMIN_USERNAME=admin
# Leave blank to auto-generate one on first run (printed once in the logs).
ADMIN_PASSWORD=

# Set to true in production (requires HTTPS in front of this service, e.g. via
# each app's nginx proxying /api/auth/* here over Tailscale HTTPS).
SECURE_COOKIE=true
